# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/voicecampaign"

# ─────────────────────────────────────────────────────────────
# Ultravox AI  →  https://ultravox.ai
# ─────────────────────────────────────────────────────────────
ULTRAVOX_API_KEY=""
ULTRAVOX_BASE_URL="https://api.ultravox.ai/api"

# ─────────────────────────────────────────────────────────────
# ElevenLabs Conversational AI  →  https://elevenlabs.io
# ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=""
ELEVENLABS_PHONE_NUMBER_ID=""

# ─────────────────────────────────────────────────────────────
# VAPI  →  https://vapi.ai
# ─────────────────────────────────────────────────────────────
VAPI_API_KEY=""
VAPI_PHONE_NUMBER_ID=""
NEXT_PUBLIC_VAPI_PUBLIC_KEY=""

# ─────────────────────────────────────────────────────────────
# Twilio (optional — for Ultravox PSTN outbound calling)
# ─────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# ─────────────────────────────────────────────────────────────
# Anthropic (for AI agent generation)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Voice Campaign Platform"

# ─────────────────────────────────────────────────────────────
# MCP Integration
# ─────────────────────────────────────────────────────────────
# Set to "true" to use ElevenLabs MCP server instead of direct HTTP
USE_ELEVENLABS_MCP="false"
# Optional: custom command to spawn the ElevenLabs MCP server
# ELEVENLABS_MCP_COMMAND="npx -y @angelogiacco/elevenlabs-mcp-server"
